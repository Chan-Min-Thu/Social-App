generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String      @id @default(uuid())
  username         String?
  email            String      @unique @db.VarChar(41)
  avatarUrl        String?
  passwordHash     String
  randomToken      String
  status           Status      @default(ACTIVE)
  lastLogin        DateTime?
  errorCount       Int         @default(0) @db.SmallInt
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  blockedIds       BlockUser[] @relation("BlockedIds")
  blockerIds       BlockUser[] @relation("BlockerIds")
  comments         Comment[]
  friendsReceived  Friend[]    @relation("FriendsReceived")
  friendsInitiated Friend[]    @relation("FriendsInitiated")
  receivedMessages Message[]   @relation("ReceivedMessages")
  sentMessages     Message[]   @relation("SentMessages")
  posts            Post[]
  Profile          Profile?
  reactions        Reaction[]
  stories          Story[]
  User_A           User[]      @relation("UserFollows")
  User_B           User[]      @relation("UserFollows")
}

model BlockUser {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("BlockedIds", fields: [blockedId], references: [id])
  blocker   User     @relation("BlockerIds", fields: [blockerId], references: [id])
}

model Friend {
  id          String   @id @default(uuid())
  requesterId String
  addresseeId String
  status      String
  createdAt   DateTime @default(now())
  addressee   User     @relation("FriendsReceived", fields: [addresseeId], references: [id])
  requester   User     @relation("FriendsInitiated", fields: [requesterId], references: [id])

  @@unique([requesterId, addresseeId])
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  bio       String
  coverUrl  String?
  location  String
  website   String
  birthDate DateTime
  gender    Gender
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Otp {
  id            String   @id @default(uuid())
  email         String   @unique
  otp           String
  rememberToken String
  verifyToken   String?
  count         Int      @default(0) @db.SmallInt
  error         Int      @default(0) @db.SmallInt
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Post {
  id        String     @id @default(uuid())
  title     String
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  authorId  String
  comments  Comment[]
  image     Image[]
  author    User       @relation(fields: [authorId], references: [id])
  reactions Reaction[]
}

model Image {
  id        String   @id @default(uuid())
  imageUrl  String
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String     @id @default(uuid())
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  authorId  String
  postId    String
  parentId  String?
  author    User       @relation(fields: [authorId], references: [id])
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  post      Post       @relation(fields: [postId], references: [id])
  reaction  Reaction[]
}

model Story {
  id        String     @id @default(uuid())
  imageUrl  String
  createdAt DateTime   @default(now())
  expiresAt DateTime
  authorId  String
  reaction  Reaction[]
  author    User       @relation(fields: [authorId], references: [id])
}

model Reaction {
  id        String       @id @default(uuid())
  type      ReactionType
  createdAt DateTime     @default(now())
  userId    String
  postId    String?
  commentId String?
  storyId   String?
  comment   Comment?     @relation(fields: [commentId], references: [id])
  post      Post?        @relation(fields: [postId], references: [id])
  Story     Story?       @relation(fields: [storyId], references: [id])
  user      User         @relation(fields: [userId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  content    String
  createdAt  DateTime @default(now())
  senderId   String
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
}

enum ReactionType {
  LOVE
}

enum Status {
  ACTIVE
  FREEZE
  BLOCK
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
